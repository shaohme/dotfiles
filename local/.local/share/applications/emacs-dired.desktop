[Desktop Entry]
Version=1.0
Name=GNU Emacs Dired
GenericName=Emacs File Browser
Comment=View and edit files
MimeType=inode/directory;application/x-directory;
# Exec=emacsclient -c --eval '(dired "%f")'
Exec=emacs --eval '(dired "%F")'
Icon=/usr/share/icons/hicolor/scalable/apps/emacs.svg
Type=Application
Terminal=true
Categories=GTK;System;Filesystem;
StartupWMClass=Emacs

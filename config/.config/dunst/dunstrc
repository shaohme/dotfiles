[global]
    font                 = Monospace 12
    markup               = yes
    plain_text           = no
    format               = "%s\n%b"
    transparency         = 0
    ignore_newline       = no
    show_indicators      = yes
    separator_color      = #f3f4f5

    sort                 = yes
    alignment            = left
    bounce_freq          = 0
    word_wrap            = yes

    indicate_hidden      = yes
    show_age_threshold   = 60
    idle_threshold       = 120

    geometry             = "500x3-30+45"
    line_height          = 0
    notification_height  = 100
    separator_height     = 2
    padding              = 16
    horizontal_padding   = 18
    frame_width          = 1
    frame_color          = "#1793d1"

    monitor              = 0
    follow               = mouse

    sticky_history       = yes
    history_length       = 20

    icon_position        = left
    icon_path            = /usr/share/icons/Adwaita/24x24/legacy/:/usr/share/icons/Adwaita/24x24/devices/

    startup_notification = false
    browser = /usr/bin/firefox -new-tab

[shortcuts]
    close     = ctrl+space
    close_all = ctrl+shift+space
#    history   = ctrl+grave
    context   = ctrl+shift+period

[urgency_low]
    background = "#586e75"
    foreground = "#eee8d5"
    timeout = 2

[urgency_normal]
    background = "#073642"
    foreground = "#eee8d5"
    timeout = 4

[urgency_critical]
    background = "#dc322f"
    foreground = "#eee8d5"
    timeout = 12
